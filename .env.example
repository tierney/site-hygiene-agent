# Site Hygiene Agent Configuration

# The main website to audit
PRIMARY_DOMAIN=https://www.example.org

# A comma-separated list of social media profiles to audit for link integrity
SOCIAL_MEDIA_PROFILES=https://www.youtube.com/@examplechannel,https://www.facebook.com/examplepage

# Decommissioned domains to watch for domain squatting/hijacking
DECOMMISSIONED_DOMAINS=example-online.org,example-network.org
